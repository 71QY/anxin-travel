# 环境变量配置示例（生产环境请使用真实值）
# 复制此文件为 .env 并在其中填写真实配置

# 数据库配置
DB_USERNAME=root
DB_PASSWORD=your_database_password

# JWT 密钥（生产环境必须修改为随机字符串）
JWT_SECRET=your_jwt_secret_key_change_in_production

# 高德地图 API Key
AMAP_WEB_API_KEY=your_amap_web_api_key

# 通义千问 API Key
TONGYI_API_KEY=your_tongyi_api_key

# 腾讯地图 API Key（需在腾讯位置服务控制台申请）
# 1. 访问 https://lbs.qq.com/ 注册并登录
# 2. 进入控制台 -> 应用管理 -> 我的应用 -> 创建应用
# 3. 添加 Key 时务必勾选 "WebServiceAPI" 产品
TENCENT_MAP_KEY=your_tencent_map_key
